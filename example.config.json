{
  "sites": [
    {
      "url": "https://example.com",
      "max_depth": 1,
      "media_selectors": ["img", "video"],
      "link_selectors": ["a[href]"]
    }
  ],
  "threads": 4,
  "output_dir": "output",
  "frame_rate": 1,
  "gc_interval": 100,
  "keep_files": false,
  "user_agent": "ruby-ocr-crawler/1.0",
  "proxy": "http://user:password@proxy.example.com:3128",
  "tor_circuit_interval": 0
}
